# ── Hostinger VPS production env ───────────────────────────────────────
# Copy to .env.production on the server and fill in REAL values.
# Never commit this file. The example below is a TEMPLATE only.

# Your public domain (Caddy uses this for SSL certificate provisioning)
DOMAIN=demo.yourdomain.com

# ── Database (Postgres runs inside docker-compose) ─────────────────────
POSTGRES_USER=app_user
POSTGRES_PASSWORD=CHANGE_ME_TO_A_LONG_RANDOM_STRING
POSTGRES_DB=ingest_insight_act

# ── Anthropic ──────────────────────────────────────────────────────────
# Leave MOCK_CLAUDE=true to use canned responses (free).
# Set MOCK_CLAUDE=false + a real key to enable live Claude calls.
ANTHROPIC_API_KEY=sk-ant-...
MOCK_CLAUDE=true

# ── Auth / Dev bypass ──────────────────────────────────────────────────
# Lock the dev bypass to a single demo tenant UUID (see DEPLOY.md step 4).
# Leave EMPTY in true production to force JWT-only auth.
DEV_TENANT_ID=

# Supabase (only needed when DEV_TENANT_ID is unset and real JWT auth is on)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── CORS ───────────────────────────────────────────────────────────────
# Comma-separated. docker-compose overrides this to https://${DOMAIN} at runtime.
CORS_ORIGINS=https://demo.yourdomain.com

# ── Rate limits (slowapi format) ───────────────────────────────────────
RATE_LIMIT_SEED=5/hour
RATE_LIMIT_LLM=20/hour

# ── App ────────────────────────────────────────────────────────────────
ENVIRONMENT=production
LOG_LEVEL=INFO
SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_STRING

# ── GA4 (optional — only needed if you want real ingestion working) ───
GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/ga4-service-account.json
